APP_NAME=AI Chat Live2D Backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Primary phase 1 target: PostgreSQL + SQLAlchemy
DATABASE_URL=sqlite+aiosqlite:///./phase1.db
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_chat_live2d
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_JWT_SECRET=change-me-admin-secret
ADMIN_TOKEN_TTL_SECONDS=86400
ADMIN_KNOWLEDGE_UPLOAD_DIR=./storage/uploads/admin/knowledge
ADMIN_KNOWLEDGE_MAX_BYTES=52428800
ADMIN_VOICE_UPLOAD_DIR=./storage/uploads/admin/voice_profiles
ADMIN_VOICE_MAX_BYTES=33554432
ANALYTICS_SCHEDULER_ENABLED=true
ANALYTICS_SCHEDULER_INTERVAL_SECONDS=3600
ANALYTICS_SCHEDULER_CATCHUP_DAYS=2
ANALYTICS_REPORT_SAMPLE_SESSIONS=8

DEFAULT_AVATAR_MODEL_PATH=/live2d/models/guide/guide.model3.json
DEFAULT_AVATAR_VOICE_ID=zh-CN-XiaoxiaoNeural
DEFAULT_AVATAR_PERSONA=你是一名景区 AI 数字导览员，回答要友好、简洁，优先帮助游客完成参观与问路。

# Reserved for the next phase when LLM/RAG is introduced.
DASHSCOPE_API_KEY=
# Quick-start shared domain for China (Beijing).
# Recommended for production: https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-plus
# Vision recognition uses the OpenAI-compatible chat/completions endpoint with a base64 data URL.
DASHSCOPE_VL_MODEL=qwen-vl-max
# Local storage directory for visitor-uploaded images before/after recognition.
VISITOR_UPLOAD_DIR=./storage/uploads/visitor
# Project-side upload guard in bytes. Keep below the DashScope 10 MB base64 request ceiling.
VISITOR_IMAGE_MAX_BYTES=6291456

# Phase 2 defaults to faster-whisper for real speech recognition.
ASR_ENGINE=faster-whisper
# Recommended: download the model snapshot first to avoid first-request download stalls.
# ASR_MODEL_NAME=./storage/models/faster-whisper-small
ASR_MODEL_NAME=small
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_LANGUAGE=zh
ASR_MOCK_TRANSCRIPT=你好，请介绍一下这个景区。

# Phase 2 uses local CosyVoice2 for emotion-aware real speech output.
# 4060 本机推荐：主模型走 cuda，CosyVoice ONNX 前端、RAG reranker、知识库向量化继续走 cpu。
TTS_ENGINE=cosyvoice
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz
TTS_COSYVOICE_MODEL_PATH=./storage/models/CosyVoice2-0.5B
TTS_COSYVOICE_CODE_PATH=./storage/vendor/CosyVoice
TTS_COSYVOICE_DEVICE=cuda
TTS_COSYVOICE_ONNX_PROVIDER=cpu
TTS_COSYVOICE_SAMPLE_RATE=24000
TTS_COSYVOICE_FP16=true
TTS_COSYVOICE_LOAD_JIT=false
TTS_SEGMENT_SOFT_MIN_CHARS=12
TTS_SEGMENT_SOFT_MAX_CHARS=20
TTS_SEGMENT_HARD_MAX_CHARS=28
DEFAULT_TTS_REFERENCE_AUDIO_PATH=./storage/vendor/CosyVoice/asset/zero_shot_prompt.wav
DEFAULT_TTS_REFERENCE_TEXT=希望你以后能够做得比我还好。
DEFAULT_TTS_SPEED=1.0
DEFAULT_TTS_EMOTION_ENABLED=true

CHAT_MODE=rag
RAG_RETRIEVAL_TOP_K=8
RAG_RERANK_TOP_N=4
RAG_CONTEXT_DOCS=3
RAG_CONTEXT_CHARS_PER_CHUNK=520
RAG_MIN_RETRIEVAL_SCORE=0.08
RAG_GENERATION_TEMPERATURE=0.2
RAG_GENERATION_MAX_TOKENS=360
# Use "lexical" for immediate local validation, or switch to "bge-reranker-v2-m3"
# after downloading the reranker model snapshot.
RAG_RERANKER_ENGINE=lexical
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER_DEVICE=cpu
RAG_RERANKER_BATCH_SIZE=4
WEBSOCKET_CHUNK_SIZE=24
REQUEST_TIMEOUT_SECONDS=10

KNOWLEDGE_BASE_DIR=./storage/knowledge
KNOWLEDGE_COLLECTION_NAME=phase1_scenic_knowledge
# Can be either "BAAI/bge-m3" or a local snapshot path such as ./storage/models/bge-m3
KNOWLEDGE_EMBEDDING_ENGINE=bge-m3
KNOWLEDGE_EMBEDDING_MODEL=BAAI/bge-m3
KNOWLEDGE_EMBEDDING_DEVICE=cpu
KNOWLEDGE_EMBEDDING_BATCH_SIZE=8
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=64
