APP_NAME=AI Chat Live2D Backend
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://ai_chat:ai_chat_pg_2026@postgres:5432/ai_chat_live2d
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:8080","http://127.0.0.1:8080","http://localhost:18080","http://127.0.0.1:18080"]

# Optional proxy settings for locked-down servers.
# HTTP_PROXY=http://127.0.0.1:17897
# HTTPS_PROXY=http://127.0.0.1:17897
# ALL_PROXY=socks5://127.0.0.1:17897
# http_proxy=http://127.0.0.1:17897
# https_proxy=http://127.0.0.1:17897
# all_proxy=socks5://127.0.0.1:17897
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost

DEFAULT_AVATAR_MODEL_PATH=/live2d/haru/haru_greeter_t03.model3.json
DEFAULT_AVATAR_VOICE_ID=zh-CN-XiaoxiaoNeural
DEFAULT_AVATAR_RESPONSE_LANGUAGE=zh
DEFAULT_AVATAR_PERSONA=你是一名景区 AI 数字导览员，回答要友好、简洁，优先帮助游客完成参观与问路。

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_JWT_SECRET=ai-chat-admin-secret-2026
ADMIN_TOKEN_TTL_SECONDS=86400
ADMIN_KNOWLEDGE_UPLOAD_DIR=/data/uploads/admin/knowledge
ADMIN_VOICE_UPLOAD_DIR=/data/uploads/admin/voice_profiles

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-flash
DASHSCOPE_VL_MODEL=qwen-vl-max
VISITOR_UPLOAD_DIR=/data/uploads/visitor

ASR_ENGINE=faster-whisper
ASR_MODEL_NAME=/models/faster-whisper-small
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_LANGUAGE=zh
ASR_MOCK_TRANSCRIPT=你好，请介绍一下这个景区。

TTS_ENGINE=cosyvoice
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz
TTS_COSYVOICE_MODEL_PATH=/models/CosyVoice2-0.5B
TTS_COSYVOICE_CODE_PATH=/vendor/CosyVoice
TTS_COSYVOICE_DEVICE=cuda
TTS_COSYVOICE_ONNX_PROVIDER=cuda
TTS_COSYVOICE_SAMPLE_RATE=24000
TTS_COSYVOICE_FP16=true
TTS_COSYVOICE_LOAD_JIT=false
TTS_COSYVOICE_LOAD_TRT=true
TTS_COSYVOICE_TRT_CONCURRENT=1
TTS_PROVIDER=local
TTS_REMOTE_URL=
TTS_REMOTE_PROTOCOL=http_stream
TTS_STREAM_PROFILE=stable
TTS_SEGMENT_SOFT_MIN_CHARS=12
TTS_SEGMENT_SOFT_MAX_CHARS=20
TTS_SEGMENT_HARD_MAX_CHARS=28
DEFAULT_TTS_REFERENCE_AUDIO_PATH=/vendor/CosyVoice/asset/zero_shot_prompt.wav
DEFAULT_TTS_REFERENCE_TEXT=希望你以后能够做得比我还好。
DEFAULT_TTS_SPEED=1.0
DEFAULT_TTS_EMOTION_ENABLED=true

CHAT_MODE=rag
RAG_RESPONSE_MODE=fast_humanized
RAG_RETRIEVAL_TOP_K=8
RAG_RERANK_TOP_N=4
RAG_CONTEXT_DOCS=3
RAG_CONTEXT_CHARS_PER_CHUNK=520
RAG_MIN_RETRIEVAL_SCORE=0.08
RAG_GENERATION_TEMPERATURE=0.2
RAG_GENERATION_MAX_TOKENS=360
RAG_RERANKER_ENGINE=bge-reranker-v2-m3
RAG_RERANKER_MODEL=/models/bge-reranker-v2-m3
RAG_RERANKER_DEVICE=cuda
RAG_RERANKER_BATCH_SIZE=4
WEBSOCKET_CHUNK_SIZE=24
REQUEST_TIMEOUT_SECONDS=10

KNOWLEDGE_BASE_DIR=/data/knowledge
KNOWLEDGE_COLLECTION_NAME=phase1_scenic_knowledge
KNOWLEDGE_EMBEDDING_ENGINE=bge-m3
KNOWLEDGE_EMBEDDING_MODEL=/models/bge-m3
KNOWLEDGE_EMBEDDING_DEVICE=cuda
KNOWLEDGE_EMBEDDING_BATCH_SIZE=8
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=64

ANALYTICS_SCHEDULER_ENABLED=true
ANALYTICS_SCHEDULER_INTERVAL_SECONDS=3600
ANALYTICS_SCHEDULER_CATCHUP_DAYS=2
ANALYTICS_REPORT_SAMPLE_SESSIONS=8
